# Environment Variables Template
# Copy this file to .env and update with your values

# Airflow Configuration
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# dbt Configuration
DBT_DIR=/opt/airflow/dbt
DBT_PROFILES_DIR=/opt/airflow/dbt

# Optional: Email alerts (comment out email_on_failure in DAG to disable)
# AIRFLOW_ALERT_EMAIL=your-email@example.com

# Optional: JWT secrets for Airflow API
# AIRFLOW__API_AUTH__JWT_SECRET=your-jwt-secret
# AIRFLOW__API_AUTH__JWT_ISSUER=airflow
